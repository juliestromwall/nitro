# Staging environment (Vite loads this for `--mode staging`).
# Copy to `.env.staging` and fill with your STAGING Supabase project's values
# (Supabase Dashboard → staging project → Project Settings → API).
# `.env.staging` is gitignored; this .example is the committed template.

VITE_SUPABASE_URL=https://YOUR-STAGING-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-anon-key

# Reuse prod's Stripe *publishable* (test) key, or a dummy — billing is
# bypassed in staging (test users are plan=free).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
