{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nitro",
  "compatibility_date": "2026-05-28",
  "workers_dev": true,
  "routes": [
    { "pattern": "app.repcommish.com", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
